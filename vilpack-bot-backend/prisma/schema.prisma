generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                 String               @id @default(uuid())
  name               String
  slug               String               @unique
  phoneNumber        String
  categories         Category[]
  sessions           Session[]
  orders             Order[]
  // WhatsApp module — relações aditivas, não alteram comportamento existente
  whatsappInstances  WhatsappInstance[]
  automationRules    AutomationRule[]
  botKnowledgeItems  BotKnowledgeItem[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id])
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String      @id @default(uuid())
  name             String
  description      String?
  price            Decimal     @db.Decimal(10, 2)
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id])
  image            String?
  imageUrl         String?
  active           Boolean     @default(true)
  // ── Vitrine (seção pública "Nossos Produtos") ────────────────────────────────
  showInVitrine    Boolean     @default(false)  // aparece no site público?
  vitrineSegment   String?                      // filtro de segmento (ex: "Alimentício")
  vitrineTags      String?                      // tags separadas por vírgula (ex: "Biodegradável,BPA Free")
  vitrineOrder     Int         @default(0)      // ordem de exibição (menor = primeiro)
  cartItems        CartItem[]
  orderItems       OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Session {
  id        String    @id @default(uuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  cart      Cart?
  messages  Message[]
  orders    Order[]
  lead      Lead?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// NOTE: Lead NÃO tem array reverso para WhatsappContact.
// WhatsappContact possui FK opcional leadId→Lead para vínculo pontual,
// mas o módulo WhatsApp não depende do modelo Lead para funcionar.
model Lead {
  id                   String                  @id @default(uuid())
  sessionId            String                  @unique
  session              Session                 @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name                 String?
  whatsapp             String?
  email                String?
  segment              String?
  companyName          String?
  city                 String?                 // cidade / região do cliente
  interestSummary      String?
  productsOfInterest   String?
  internalNotes        String?
  leadSource           String                  @default("chat_vik")
  status               String                  @default("NEW")
  priority             String                  @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  isRead               Boolean                 @default(false)
  followUpAt           DateTime?
  qualificationScore   Int                     @default(0)
  lastLeadExtractionAt DateTime?
  lastLeadContextHash  String?
  lastInteractionAt    DateTime                @default(now())
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  // ── Ficha Comercial ──────────────────────────────────────────────────────────
  lastPurchaseAt        DateTime?               // data da última compra
  lastPurchaseValue     Decimal?   @db.Decimal(10,2) // valor da última compra
  lastUnitPrice         String?                 // último preço unitário anotado (texto livre)
  mainProducts          String?                 // produtos mais comprados (texto livre, csv)
  purchaseFrequency     String?                 // frequência estimada (ex: "mensal", "quinzenal")
  avgTicket             Decimal?   @db.Decimal(10,2) // ticket médio estimado
  commercialCondition   String?                 // condição comercial habitual (ex: "30 dias", "à vista 5%")
  nextAction            String?                 // próxima ação recomendada (texto livre)
  summary              LeadConversationSummary?
}

model LeadConversationSummary {
  id                    String   @id @default(uuid())
  leadId                String   @unique
  lead                  Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  summary               String?
  needDescription       String?
  detectedIntent        String?
  nextRecommendedAction String?
  lastAiUpdateAt        DateTime @default(now())
}

model Cart {
  id        String     @id @default(uuid())
  sessionId String     @unique
  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())
}

model Order {
  id            String      @id @default(uuid())
  storeId       String
  store         Store       @relation(fields: [storeId], references: [id])
  sessionId     String?
  session       Session?    @relation(fields: [sessionId], references: [id])
  customerName  String?
  customerPhone String?
  orderSummary  String?
  items         OrderItem[]
  total         Decimal     @default(0.00) @db.Decimal(10, 2)
  status        String      @default("draft") // draft, lead_captured, pending, completed, canceled
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
}

model AdminUser {
  id          String               @id @default(uuid())
  username    String               @unique
  password    String
  role        String               @default("VIEWER") // MASTER, VIEWER
  assignments WhatsappAssignment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

// ─────────────────────────────────────────────────────────────────
// WHATSAPP MODULE — tabelas completamente isoladas
// NÃO reutilizam Session, Message, nem Cart do SmartChat público.
// O módulo é autônomo: instância → conversa → mensagem → anexo.
// ─────────────────────────────────────────────────────────────────

/// Instância da Evolution API vinculada a uma Store
model WhatsappInstance {
  id            String                 @id @default(uuid())
  storeId       String
  store         Store                  @relation(fields: [storeId], references: [id])
  instanceName  String                 @unique
  status        String                 @default("disconnected") // disconnected, connecting, connected
  qrCode        String?
  webhookUrl    String?
  botEnabled    Boolean                @default(true)
  conversations WhatsappConversation[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

/// Contato WhatsApp (número real ou grupo)
/// leadId é apenas um campo de referência — sem relação Prisma declarada,
/// para evitar acoplamento bidirecional com o modelo Lead existente.
model WhatsappContact {
  id            String                 @id @default(uuid())
  phone         String                 @unique  // e.g. "5511999990000"
  name          String?
  pushName      String?
  profilePicUrl String?
  isGroup       Boolean                @default(false)
  leadId        String?                // referência opcional ao Lead (sem @relation — desacoplado)
  conversations WhatsappConversation[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

/// Conversa (thread entre instância e contato)
model WhatsappConversation {
  id                  String                    @id @default(uuid())
  instanceId          String
  instance            WhatsappInstance          @relation(fields: [instanceId], references: [id])
  contactId           String
  contact             WhatsappContact           @relation(fields: [contactId], references: [id])
  status              String                    @default("open") // open, resolved, pending
  botEnabled          Boolean                   @default(true)  // bot ativo nesta conversa (config global)
  botPaused           Boolean                   @default(false) // pausa temporária por takeover humano
  assignedAdminUserId String?                   // último admin atribuído (denormalizado para consulta rápida)
  unreadCount         Int                       @default(0)
  lastMessageAt       DateTime?
  messages            WhatsappMessage[]
  tags                WhatsappConversationTag[]
  assignments         WhatsappAssignment[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([instanceId, contactId])
  @@index([instanceId, status])         // filtro por instância+status (inbox)
  @@index([instanceId, lastMessageAt])  // ordenação por última mensagem
}

/// Mensagem trafegada pelo WhatsApp
/// providerMessageId: ID externo do provider (Evolution) — deduplicação de mensagens
/// providerEventId:   ID externo do evento webhook — deduplicação de eventos duplicados
model WhatsappMessage {
  id                String               @id @default(uuid())
  conversationId    String
  conversation      WhatsappConversation @relation(fields: [conversationId], references: [id])
  providerMessageId String?              @unique  // ID da mensagem no provider (deduplicação)
  providerEventId   String?              @unique  // ID do evento webhook (deduplicação de entrega dupla)
  direction         String               // inbound | outbound
  fromMe            Boolean              @default(false)
  type              String               @default("text") // text | image | audio | document | sticker | reaction
  content           String?
  status            String               @default("sent") // sent | delivered | read | failed
  attachments       WhatsappAttachment[]
  botExecutionLogs  BotExecutionLog[]
  timestamp         DateTime             @default(now())
  createdAt         DateTime             @default(now())

  @@index([conversationId, timestamp])  // paginação de mensagens por conversa
}

/// Anexo de mídia vinculado a uma mensagem
model WhatsappAttachment {
  id         String          @id @default(uuid())
  messageId  String
  message    WhatsappMessage @relation(fields: [messageId], references: [id])
  type       String          // image | audio | document | video
  mimeType   String?
  fileName   String?
  fileSize   Int?
  storageKey String          // chave no storage (S3 ou local)
  url        String?         // URL pública/assinada (gerada sob demanda)
  createdAt  DateTime        @default(now())
}

/// Tag de conversa (ex.: "urgente", "orçamento", "suporte")
model WhatsappConversationTag {
  id             String               @id @default(uuid())
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id])
  tag            String
  createdAt      DateTime             @default(now())

  @@unique([conversationId, tag])
}

/// Atribuição de conversa a um agente/admin (histórico completo)
model WhatsappAssignment {
  id             String               @id @default(uuid())
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id])
  adminUserId    String
  adminUser      AdminUser            @relation(fields: [adminUserId], references: [id])
  assignedAt     DateTime             @default(now())
}

/// Regra de automação do bot (horário, status, fila)
model AutomationRule {
  id           String   @id @default(uuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  name         String
  trigger      String   // keyword | always | outside_hours
  triggerValue String?  // palavra-chave, etc.
  action       String   // reply | handoff | tag | assign
  actionValue  String?  // texto da resposta, nome da tag, etc.
  active       Boolean  @default(true)
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Item de conhecimento para o bot (RAG futuro)
model BotKnowledgeItem {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  title     String
  content   String
  tags      String[] // array de tags para filtragem
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Log de execução do bot para rastreabilidade
model BotExecutionLog {
  id         String          @id @default(uuid())
  messageId  String
  message    WhatsappMessage @relation(fields: [messageId], references: [id])
  decision   String          // replied | handed_off | ignored | rule_matched
  reasoning  String?         // motivo da decisão
  ruleId     String?         // se disparado por AutomationRule
  tokensUsed Int?
  latencyMs  Int?
  createdAt  DateTime        @default(now())
}
