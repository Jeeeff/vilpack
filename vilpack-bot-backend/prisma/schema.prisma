generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  phoneNumber String
  categories  Category[]
  sessions    Session[]
  orders      Order[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id])
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String     @id @default(uuid())
  name        String
  description String?
  price       Decimal    @db.Decimal(10, 2)
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  image       String?
  imageUrl    String?
  active      Boolean    @default(true)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Session {
  id        String    @id @default(uuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  cart      Cart?
  messages  Message[]
  orders    Order[]
  lead      Lead?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Lead {
  id                 String     @id @default(uuid())
  sessionId          String     @unique
  session            Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name               String?
  whatsapp           String?
  email              String?
  segment            String?
  companyName        String?
  interestSummary    String?
  productsOfInterest String?
  internalNotes      String?    
  leadSource         String     @default("chat_vik")
  status             String     @default("NEW") 
  priority           String     @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  isRead             Boolean    @default(false)    // Controle de notificações
  followUpAt         DateTime?                     // Agendamento de follow-up
  qualificationScore Int        @default(0)
  lastInteractionAt  DateTime   @default(now())
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  summary            LeadConversationSummary?
}

model LeadConversationSummary {
  id                    String   @id @default(uuid())
  leadId                String   @unique
  lead                  Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  summary               String?
  needDescription       String?
  detectedIntent        String?
  nextRecommendedAction String?
  lastAiUpdateAt        DateTime @default(now())
}

model Cart {
  id        String     @id @default(uuid())
  sessionId String     @unique
  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())
}

model Order {
  id            String      @id @default(uuid())
  storeId       String
  store         Store       @relation(fields: [storeId], references: [id])
  sessionId     String?
  session       Session?    @relation(fields: [sessionId], references: [id])
  customerName  String?
  customerPhone String?
  orderSummary  String?
  items         OrderItem[]
  total         Decimal     @default(0.00) @db.Decimal(10, 2)
  status        String      @default("draft") // draft, lead_captured, pending, completed, canceled
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
}

model AdminUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("VIEWER") // MASTER, VIEWER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
