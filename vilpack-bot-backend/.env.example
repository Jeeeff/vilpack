PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/vilpack

# Auth
JWT_SECRET=supersecretkey
ADMIN_PASSWORD=vilpack2026

# AI
GROQ_API_KEY=

# ─── Notificações de Vendas (WhatsApp da equipe) ────────────────────────────
# Habilita envio automático para a equipe quando a Vick gera um resumo
# ou uma sessão fica inativa. Não depende do painel WhatsApp.
SALES_NOTIFICATIONS_ENABLED=false
SALES_WHATSAPP_NUMBER=5511999990000     # número da equipe (só dígitos, com DDI)
SALES_INACTIVITY_MINUTES=15            # minutos sem atividade para notificar

# ─── WhatsApp / Evolution API ──────────────────────────
# Feature Flags (true | false)
ENABLE_WHATSAPP_PANEL=false
ENABLE_EVOLUTION_WEBHOOKS=false
ENABLE_WHATSAPP_BOT=false
ENABLE_WHATSAPP_MEDIA=false
ENABLE_WHATSAPP_AUDIO_TRANSCRIPTION=false
ADMIN_REALTIME_ENABLED=false

# Evolution API (usado pelas notificações de vendas E pelo painel WhatsApp)
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=vilpack
EVOLUTION_WEBHOOK_SECRET=

# Media Storage (local | s3)
WHATSAPP_MEDIA_STORAGE_DRIVER=local

# S3 (se usar driver s3)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
